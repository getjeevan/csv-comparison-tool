# ============================================================
# NetClaw — Environment Variables for Hostinger Docker
# Copy this file to .env and fill in your credentials.
# Only set what you need — every integration is optional
# except ANTHROPIC_API_KEY.
# ============================================================

# --- REQUIRED ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Network Devices (pyATS testbed) ---
# PYATS_TESTBED_PATH=/netclaw/testbed/testbed.yaml
# DEVICE_USERNAME=admin
# DEVICE_PASSWORD=

# --- Cisco Platforms ---
# MERAKI_API_KEY=
# THOUSANDEYES_TOKEN=
